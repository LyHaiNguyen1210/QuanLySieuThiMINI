<UserControl x:Class="QuanLySieuThiMINI.View.UC_NhapHang"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLySieuThiMINI.View"
             xmlns:vm="clr-namespace:QuanLySieuThiMINI.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="White">
    <UserControl.DataContext>
        <vm:QL_NhapHang/>
    </UserControl.DataContext>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📦 QUẢN LÝ NHẬP KHO &amp; DATE" FontSize="26" FontWeight="Bold" Foreground="#27AE60" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#BDC3C7" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="1"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="5">
                    <TextBlock Text="Nhà cung cấp:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox Height="32" Padding="5,0"
                      ItemsSource="{Binding DSNhaCungCap}" 
                      DisplayMemberPath="TenNCC" 
                      SelectedValuePath="MaNCC"
                      SelectedItem="{Binding SelectedNhaCungCap, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Nhập mã mặt hàng:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Height="32" VerticalContentAlignment="Center" Padding="5,0"
                     Text="{Binding TuKhoaMaMH, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Nhập mã và tên mặt hàng sẽ tự hiện bên dưới"/>
                    <TextBlock Text="{Binding TenMatHangDaTimThay}" Foreground="#2980B9" FontWeight="Bold" Margin="0,5,0,0" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="Số lượng:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Height="32" VerticalContentAlignment="Center" Padding="5,0"
                     Text="{Binding SoLuongNhap, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="5">
                    <TextBlock Text="Hạn sử dụng (Date):" FontWeight="SemiBold" Foreground="#E67E22" Margin="0,0,0,5"/>
                    <DatePicker Height="32" VerticalContentAlignment="Center" 
                        SelectedDate="{Binding NgayHetHanNhap, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <Button Grid.Column="4" Content="➕ Thêm vào phiếu" Command="{Binding ThemVaoPhieuCommand}" 
                Width="140" Height="32" Margin="10,0,0,0" Background="#2980B9" Foreground="White" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding DSChiTietNhap}" 
          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
          RowHeight="35" Background="White" BorderBrush="#BDC3C7" BorderThickness="1" AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã MH" Binding="{Binding MaMH}" Width="100"/>
                <DataGridTextColumn Header="Tên Mặt Hàng" Binding="{Binding TenMH}" Width="*"/>
                <DataGridTextColumn Header="Số Lượng" Binding="{Binding SoLuong}" Width="100"/>
                <DataGridTextColumn Header="Ngày Hết Hạn" Binding="{Binding NgayHetHan, StringFormat=dd/MM/yyyy}" Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#D35400"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Hành động" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Xóa" 
                            Command="{Binding DataContext.XoaChiTietCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                            CommandParameter="{Binding}"
                            Background="#E74C3C" Foreground="White" Width="60" Height="25" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="3"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <TextBlock Text="Người lập phiếu: " VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="{Binding TenNhanVienLap}" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontSize="14"/>

            <Button Content="🖨️ IN PHIẾU NHẬP" Command="{Binding InPhieuNhapCommand}" 
                    Height="42" Width="170" Background="#F39C12" Foreground="White" FontWeight="Bold" Cursor="Hand" Margin="0,0,15,0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="💾 LƯU PHIẾU NHẬP" Command="{Binding LuuPhieuNhapCommand}" 
                    Height="42" Width="180" Background="#27AE60" Foreground="White" FontWeight="Bold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
