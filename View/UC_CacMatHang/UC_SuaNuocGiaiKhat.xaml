<UserControl x:Class="QuanLySieuThiMINI.View.UC_SuaNuocGiaiKhat"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLySieuThiMINI.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" Tag="Tìm kiếm rau, củ, trái cây..." Height="35" VerticalContentAlignment="Center" Padding="10,0" BorderBrush="#27AE60" BorderThickness="1" Margin="0,0,0,10"/>

        <DataGrid ItemsSource="{Binding dsMH}" SelectedItem="{Binding SelectedMH}" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" BorderBrush="#27AE60" BorderThickness="1" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã" Width="60" Binding="{Binding MaMH}"/>
                <DataGridTextColumn Header="Tên Mặt Hàng" Width="3*" Binding="{Binding TenMH}"/>
                <DataGridTextColumn Header="Tình trạng" Width="100" Binding="{Binding TinhTrang}"/>
                <DataGridTextColumn Header="Số Lượng" Width="80" Binding="{Binding SoLuong}"/>
                <DataGridTextColumn Header="Đơn Giá" Width="100" Binding="{Binding DonGia}"/>
                <DataGridTextColumn Header="Vị Trí" Width="80" Binding="{Binding ViTriQuay}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#E8F8F5" CornerRadius="8" Padding="15" BorderBrush="#27AE60" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Thông tin Sữa - Nước giải khát" FontSize="18" FontWeight="Bold" Foreground="#1E8449" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Tên hàng:"/>
                        <TextBox Height="30" Text="{Binding SelectedMH.TenMH}" Margin="0,5"/>
                        <TextBlock Text="Số lượng:"/>
                        <TextBox Height="30" Text="{Binding SelectedMH.SoLuong}" Margin="0,5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Giá nhập:"/>
                        <TextBox Height="30" Text="{Binding SelectedMH.GiaNhap}" Margin="0,5"/>
                        <TextBlock Text="Vị trí:"/>
                        <TextBox Height="30" Text="{Binding SelectedMH.ViTriQuay}" Margin="0,5"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Content="➕ Thêm" Width="80" Height="35" Background="#27AE60" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="❌ Xóa" Width="80" Height="35" Background="#C0392B" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="🔄 Cập nhật" Width="100" Height="35" Background="#1E8449" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
