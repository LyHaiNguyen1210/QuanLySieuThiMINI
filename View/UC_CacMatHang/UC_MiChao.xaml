<UserControl x:Class="QuanLySieuThiMINI.View.UC_MiChao"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" Tag="Tìm kiếm mì, miến, cháo..." Height="35" VerticalContentAlignment="Center" Padding="10,0" BorderBrush="#2980B9" BorderThickness="1" Margin="0,0,0,10"/>

        <DataGrid ItemsSource="{Binding dsMH}" SelectedItem="{Binding SelectedMH}" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" BorderBrush="#2980B9" BorderThickness="1" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã" Width="60" Binding="{Binding MaMH}"/>
                <DataGridTextColumn Header="Tên Mặt Hàng" Width="3*" Binding="{Binding TenMH}"/>
                <DataGridTextColumn Header="Số Lượng" Width="80" Binding="{Binding SoLuong}"/>
                <DataGridTextColumn Header="Đơn Vị" Width="100" Binding="{Binding DonViTinh}"/>
                <DataGridTextColumn Header="Giá Bán" Width="100" Binding="{Binding DonGia}"/>
                <DataGridTextColumn Header="Barcode" Width="120" Binding="{Binding BarCode}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#EBF5FB" CornerRadius="8" Padding="15" BorderBrush="#2980B9" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Thông tin Mì - Miến - Cháo" FontSize="18" FontWeight="Bold" Foreground="#21618C" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Tên hàng:"/>
                        <TextBox Height="30" Text="{Binding SelectedMH.TenMH}" Margin="0,5"/>
                        <TextBlock Text="Barcode:"/>
                        <TextBox Height="30" Text="{Binding SelectedMH.BarCode}" Margin="0,5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Đơn giá:"/>
                        <TextBox Height="30" Text="{Binding SelectedMH.DonGia}" Margin="0,5"/>
                        <TextBlock Text="Số lượng:"/>
                        <TextBox Height="30" Text="{Binding SelectedMH.SoLuong}" Margin="0,5"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Content="➕ Thêm" Width="80" Height="35" Background="#2980B9" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="❌ Xóa" Width="80" Height="35" Background="#C0392B" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="🔄 Cập nhật" Width="100" Height="35" Background="#21618C" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>