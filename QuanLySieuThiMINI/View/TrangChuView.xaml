<Window x:Class="QuanLySieuThiMINI.View.TrangChuView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hệ thống Quản lý Siêu thị" Height="500" Width="850" 
        WindowStartupLocation="CenterScreen" Background="#F4F6F8"
        xmlns:vm="clr-namespace:QuanLySieuThiMINI.ViewModel">
    <Window.DataContext>
        <vm:TrangChuViewModel/>
    </Window.DataContext>
    <Grid>
        <StackPanel Orientation="Horizontal" Margin="20" VerticalAlignment="Top">
            <TextBlock Text="👤" FontSize="30" Margin="0,0,10,0"/>
            <StackPanel>
                <TextBlock Text="{Binding TenNhanVien}" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Chọn phân hệ làm việc hôm nay" FontSize="14" Foreground="#7F8C8D"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,30,0,0">

            <Border Background="White" BorderBrush="#006699" BorderThickness="2" Width="300" Height="250" Margin="20">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🛒" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="QUẦY THU NGÂN" FontSize="20" FontWeight="Bold" Foreground="#006699" HorizontalAlignment="Center"/>
                    <TextBlock Text="Bán hàng, quét mã vạch" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,20"/>

                    <Button Content="VÀO BÁN HÀNG" Command="{Binding MoTrangBanHangCommand}" IsEnabled="{Binding CanVaoBanHang}" 
        Width="150" Height="40" Background="#006699" Foreground="White" 
        FontSize="14" FontWeight="Bold" Cursor="Hand" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="#E67E22" BorderThickness="2" Width="300" Height="250" Margin="20">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="💼" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="QUẢN LÝ HỆ THỐNG" FontSize="20" FontWeight="Bold" Foreground="#E67E22" HorizontalAlignment="Center"/>
                    <TextBlock Text="Kho hàng, nhân sự" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,20"/>

                    <Button Content="VÀO QUẢN LÝ" Command="{Binding MoTrangMatHangCommand}" IsEnabled="{Binding CanVaoQuanLy}" 
        Width="150" Height="40" Background="#E67E22" Foreground="White" 
        FontSize="14" FontWeight="Bold"  Cursor="Hand" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Window>