<UserControl x:Class="QuanLySieuThiMINI.View.UC_NhapKho"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="PHIẾU NHẬP KHO HÀNG HÓA" FontSize="18" FontWeight="Bold" Foreground="#16A085" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding dsNH}" SelectedItem="{Binding SelectedNH}" AutoGenerateColumns="False" CanUserAddRows="False" BorderBrush="#16A085" BorderThickness="1" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Nhập" Width="100" Binding="{Binding MaNhapHang}"/>
                <DataGridTextColumn Header="Nhà Cung Cấp" Width="2*" Binding="{Binding NhaCungCap.TenNCC}"/>
                <DataGridTextColumn Header="Ngày Nhập" Width="150" Binding="{Binding NgayNhap}"/>
                <DataGridTextColumn Header="Người Nhập" Width="150" Binding="{Binding NhanVien.TenNV}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#E8F8F5" CornerRadius="8" Padding="15" BorderBrush="#16A085" BorderThickness="1">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Mã phiếu nhập:"/>
                        <TextBox Height="30" Text="{Binding SelectedNH.MaNhapHang}" Margin="0,5" Background="#F2F2F2" IsReadOnly="True"/>
                        <TextBlock Text="Nhà cung cấp:"/>
                        <ComboBox Height="30" ItemsSource="{Binding dsNCC}" DisplayMemberPath="TenNCC" SelectedValuePath="MaNCC"
                                  SelectedValue="{Binding SelectedNH.MaNCC, Mode=TwoWay}" Margin="0,5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Ngày nhập:"/>
                        <DatePicker Height="30" SelectedDate="{Binding SelectedNH.NgayNhap}" Margin="0,5"/>
                        <TextBlock Text="Ghi chú:"/>
                        <TextBox Height="30" Margin="0,5"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="📄 Tạo phiếu mới" Width="120" Height="35" Background="#16A085" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="💾 Lưu phiếu" Width="100" Height="35" Background="#1ABC9C" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>