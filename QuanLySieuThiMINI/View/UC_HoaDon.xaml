<UserControl x:Class="QuanLySieuThiMINI.View.UC_HoaDon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLySieuThiMINI.View"
             xmlns:vm="clr-namespace:QuanLySieuThiMINI.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E3F2FD" Offset="0.0" />
            <GradientStop Color="White" Offset="1.0" />
        </LinearGradientBrush>
    </UserControl.Background>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
            <TextBlock Text="QUẢN LÝ HÓA ĐƠN" FontSize="24" FontWeight="Bold" Margin="0,0,40,0" VerticalAlignment="Center"/>

            <TextBlock Text="Từ ngày:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
            <DatePicker SelectedDate="{Binding TuNgay, Mode=TwoWay}" Width="130" VerticalAlignment="Center"/>

            <TextBlock Text="Đến ngày:" VerticalAlignment="Center" Margin="20,0,10,0" FontSize="14"/>
            <DatePicker SelectedDate="{Binding DenNgay, Mode=TwoWay}" Width="130" VerticalAlignment="Center"/>

            <Button Content="Lọc Dữ Liệu" Command="{Binding LocHoaDonCommand}" Width="100" Height="30" Margin="20,0,0,0" 
                Background="#2196F3" Foreground="White" FontWeight="SemiBold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <GroupBox Grid.Row="1" Grid.Column="0" Header="Danh sách Hóa Đơn" Margin="0,0,10,0">
            <DataGrid Name="dgvHoaDon" 
                  ItemsSource="{Binding DSHoaDon}" 
                  SelectedItem="{Binding SelectedHoaDon, Mode=TwoWay}"
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" 
                  SelectionMode="Single"
                  IsReadOnly="True"
                  RowHeight="32">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã HĐ" Binding="{Binding MaHDBanHang}" Width="100"/>
                    <DataGridTextColumn Header="Ngày Lập" Binding="{Binding NgayLapHD, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                    <DataGridTextColumn Header="Nhân Viên" Binding="{Binding MaNV}" Width="90"/>
                    <DataGridTextColumn Header="Tổng Tiền" Binding="{Binding TongTien, StringFormat={}{0:N0} đ}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="1" Header="Chi tiết Hóa Đơn" Margin="10,0,0,0">
            <DataGrid Name="dgvChiTietHoaDon" 
                  ItemsSource="{Binding DSChiTietHoaDon}"
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  RowHeight="32">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã MH" Binding="{Binding MaMH}" Width="100"/>
                    <DataGridTextColumn Header="Số Lượng" Binding="{Binding SoLuong}" Width="90"/>
                    <DataGridTextColumn Header="Giảm Giá" Binding="{Binding GiamGia, StringFormat={}{0:N0} đ}" Width="100"/>
                    <DataGridTextColumn Header="Thành Tiền" Binding="{Binding ThanhTien, StringFormat={}{0:N0} đ}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>
