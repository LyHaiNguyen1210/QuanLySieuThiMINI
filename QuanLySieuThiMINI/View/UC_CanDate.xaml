<UserControl x:Class="QuanLySieuThiMINI.View.UC_CanDate"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QuanLySieuThiMINI.ViewModel"
             Background="White">
    <UserControl.DataContext>
        <Binding Source="{x:Static vm:QL_CanDate.Instance}"/>
    </UserControl.DataContext>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="CẢNH BÁO &amp; QUẢN LÝ KHO" FontSize="24" FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,20"/>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabItem Header="Hàng Sắp Hết Hạn" FontSize="14" FontWeight="SemiBold">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Content="🔄 Cập nhật dữ liệu" Command="{Binding KiemTraCanDateCommand}" 
                        HorizontalAlignment="Left" Width="180" Height="32" Margin="0,0,0,10" 
                        Background="#F39C12" Foreground="White" FontWeight="Bold" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <DataGrid Grid.Row="1" Name="dgvSapHetHan" 
                          ItemsSource="{Binding DSSapHetHan}" 
                          AutoGenerateColumns="False" 
                          Background="White" BorderBrush="#DDD"
                          IsReadOnly="True" CanUserAddRows="False" RowHeight="32">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã Cận Date" Binding="{Binding MaCanDate}" Width="100"/>
                            <DataGridTextColumn Header="Mã MH" Binding="{Binding MaMH}" Width="80"/>
                            <DataGridTextColumn Header="Tên Mặt Hàng" Binding="{Binding TenMH}" Width="*"/>
                            <DataGridTextColumn Header="Số Lượng" Binding="{Binding SoLuong}" Width="80"/>
                            <DataGridTextColumn Header="Ngày Hết Hạn" Binding="{Binding NgayHetHan, StringFormat=dd/MM/yyyy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Danh Sách Hàng Hủy" FontSize="14" FontWeight="SemiBold">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="➕ Lập phiếu hủy" Command="{Binding LapPhieuHuyCommand}" 
                            Width="140" Height="32" Background="#E74C3C" Foreground="White" FontWeight="Bold" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    <DataGrid Grid.Row="1" Name="dgvHuyHang" 
                          ItemsSource="{Binding DSHuyHang}" 
                          AutoGenerateColumns="False" 
                          Background="White" BorderBrush="#DDD"
                          IsReadOnly="True" CanUserAddRows="False" RowHeight="32">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã Phiếu" Binding="{Binding MaHangHuy}" Width="80"/>
                            <DataGridTextColumn Header="Mã MH" Binding="{Binding MaMH}" Width="80"/>
                            <DataGridTextColumn Header="Tên Mặt Hàng" Binding="{Binding TenMH}" Width="200"/>
                            <DataGridTextColumn Header="Số Lượng" Binding="{Binding SoLuong}" Width="80"/>
                            <DataGridTextColumn Header="Ngày Hủy" Binding="{Binding NgayHuy, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                            <DataGridTextColumn Header="Lý Do Hủy" Binding="{Binding LyDo}" Width="*"/>
                            <DataGridTextColumn Header="Trạng Thái" Binding="{Binding TrangThaiDuyet}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>